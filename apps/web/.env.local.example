# Browser-facing base URL for the FastAPI backend (used by the public lead form).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side base URL used by route handlers and server components.
# In Docker Compose this is the service name, e.g. http://api:8000.
# Falls back to NEXT_PUBLIC_API_URL when unset.
# API_INTERNAL_URL=http://api:8000
