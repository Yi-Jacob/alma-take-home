# ---- Database ----
# SQLAlchemy URL for the Postgres database (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://alma:alma@localhost:5433/alma

# ---- Auth / JWT ----
# Secret used to sign access tokens. CHANGE THIS in production.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
# Access token lifetime in minutes (default 8 hours).
ACCESS_TOKEN_TTL_MINUTES=480

# ---- Seeded attorney account (created on startup if missing) ----
ATTORNEY_EMAIL=attorney@example.com
ATTORNEY_PASSWORD=password123

# ---- Email ----
# "console" logs emails to stdout (no credentials needed); "smtp" sends via SMTP.
EMAIL_BACKEND=console   # console | resend | smtp
EMAIL_FROM=no-reply@example.com
# Where new-lead notifications are sent.
ATTORNEY_NOTIFY_EMAIL=attorney@example.com
# SMTP settings (only used when EMAIL_BACKEND=smtp).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# ---- Storage ----
STORAGE_BACKEND=local
# Directory where uploaded resumes are stored.
UPLOAD_DIR=uploads
# Public base URL the API is reached at (used to build resume download links).
PUBLIC_API_URL=http://localhost:8000

# ---- CORS ----
# The web frontend origin allowed to call the API.
WEB_ORIGIN=http://localhost:3000

# ---- Resume upload constraints ----
MAX_RESUME_BYTES=10485760

# Only used when EMAIL_BACKEND=resend (free tier: EMAIL_FROM=onboarding@resend.dev).
RESEND_API_KEY=
