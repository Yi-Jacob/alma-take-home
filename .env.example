# Copy to .env for `docker compose up`, or into apps/api/.env for a manual run.
# docker-compose.yml reads this file automatically. Every value has a safe local
# default baked into the app, so you only need to set what you want to change.
#
# NOTE: apps/api reads UPPERCASE env vars that map 1:1 to the pydantic-settings
# fields in apps/api/app/core/config.py.

# --- Postgres (used by the db service and to build DATABASE_URL) ---
POSTGRES_USER=alma
POSTGRES_PASSWORD=alma
POSTGRES_DB=alma
# Host port the db service is published on (5433 by default so a local
# Postgres on 5432 doesn't clash).
POSTGRES_HOST_PORT=5433

# --- Database (API) ---
# Inside Compose the host is `db:5432`; for a manual API run against the
# compose db service, use localhost:${POSTGRES_HOST_PORT}.
DATABASE_URL=postgresql+psycopg://alma:alma@localhost:5433/alma

# --- Auth / JWT ---
# CHANGE THIS to a long random string outside local dev.
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=480

# --- Seeded attorney account (created on API startup if it does not exist) ---
ATTORNEY_EMAIL=attorney@example.com
ATTORNEY_PASSWORD=password123

# --- Email ---
# console -> both emails are logged to the API's stdout (see `docker compose logs api`).
# resend  -> real delivery through https://resend.com (requires RESEND_API_KEY).
# smtp    -> uses the SMTP_* settings below.
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@example.com
ATTORNEY_NOTIFY_EMAIL=attorney@example.com
# Only used when EMAIL_BACKEND=resend. With Resend's free tier, use
# EMAIL_FROM=onboarding@resend.dev and your own address as ATTORNEY_NOTIFY_EMAIL.
RESEND_API_KEY=
# Only used when EMAIL_BACKEND=smtp:
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# --- Storage ---
STORAGE_BACKEND=local
# Where resume files are written. Compose overrides this to /data/uploads (a volume).
UPLOAD_DIR=uploads
MAX_RESUME_BYTES=10485760

# --- URLs / CORS ---
# Public base URL the API is reached at; used to build resume download links.
PUBLIC_API_URL=http://localhost:8000
# Browser origin allowed to call the API (CORS).
WEB_ORIGIN=http://localhost:3000

# --- Frontend (apps/web) ---
# Base URL the browser uses.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Base URL the Next.js server uses to reach the API. In Compose this is
# http://api:8000; for a fully manual run use http://localhost:8000.
API_INTERNAL_URL=http://localhost:8000
